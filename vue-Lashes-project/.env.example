# 复制为 .env.local 后填入真实值（勿提交 .env.local）

# 二选一或同时存在时的优先级：Supabase > 通用 REST（VITE_API_BASE_URL）> 本地 localStorage
# 配置 Supabase 后：请在控制台执行 supabase/schema.sql，并在 Authentication 中创建管理员用户。

# Supabase（Project Settings → API）
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 可选：自建 REST 后端（未配置 Supabase 时生效）
# VITE_API_BASE_URL=https://your-api.example.com

# 通知链路（预约成功后优先邮件，不可用时走短信模拟）
# 管理员通知邮箱（多个逗号分隔）
# VITE_BOOKING_ADMIN_EMAILS=owner@example.com,manager@example.com

# 可选：Supabase Edge Function 名称（默认 booking-notify）
# VITE_SUPABASE_NOTIFY_FUNCTION=booking-notify

# --- AI 服务推荐（Edge Function `service-recommend`，见 supabase/functions/service-recommend）---
# 服务端调用 DeepSeek（OpenAI 兼容 Chat Completions + json_object）。Supabase Secrets 示例：
#   supabase secrets set DEEPSEEK_API_KEY=sk-...
#   可选：DEEPSEEK_MODEL（默认 deepseek-chat）、DEEPSEEK_API_BASE_URL（默认 https://api.deepseek.com）
# 部署：supabase functions deploy service-recommend
# VITE_ENABLE_OPENAI_SERVICE_RECOMMEND=true
# VITE_SUPABASE_SERVICE_RECOMMEND_FUNCTION=service-recommend
